{
  "hosting": {
    "public": "influnet",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "main.py",
      ".replit",
      "REPLIT_DEPLOY.md",
      "scripts/**",
      "influnet.io/**"
    ],
    "headers": [
      {
        "source": "/Asset/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ],
    "redirects": [
      {
        "source": "/app",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/app/",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/app/**",
        "destination": "/:splat",
        "type": 301
      },
      {
        "source": "/pricing",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/pricing/**",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/influencer/:slug",
        "destination": "/influnet/:slug",
        "type": 301
      },
      {
        "source": "/profile/:slug",
        "destination": "/influnet/:slug",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
